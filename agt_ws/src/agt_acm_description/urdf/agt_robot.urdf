<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mk_mini_visual">

  <!--
    MK-mini simplified visual model

    Frame convention:
    - base_footprint: rear axle midpoint projected onto ground
    - base_link: rear axle midpoint at wheel-center height
    - x forward, y left, z up

    Notes:
    - This is still a visual-only model.
    - base_link stays at the rear axle midpoint at wheel-center height.
    - Wheel and steering joints are added for clearer Ackermann-style TF semantics.
  -->

  <!-- ========================= Dimensions ========================= -->
  <xacro:property name="body_length" value="0.84"/>
  <xacro:property name="body_width" value="0.50"/>
  <xacro:property name="body_height" value="0.31"/>

  <xacro:property name="wheel_base" value="0.60"/>
  <xacro:property name="track_width" value="0.517"/>
  <xacro:property name="ground_clearance" value="0.111"/>

  <xacro:property name="wheel_diameter" value="0.24"/>
  <xacro:property name="wheel_width" value="0.08"/>
  <xacro:property name="wheel_radius" value="${wheel_diameter / 2.0}"/>
  <xacro:property name="half_track" value="${track_width / 2.0}"/>

  <!-- ========================= Reusable wheel ========================= -->
  <xacro:macro name="wheel_link" params="name rgba">
    <link name="${name}">
      <visual>
        <!-- cylinder default axis is z, rotate to y so wheel axle is along y -->
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="${name}_mat">
          <color rgba="${rgba}"/>
        </material>
      </visual>
    </link>
  </xacro:macro>

  <xacro:macro name="steering_link" params="name">
    <link name="${name}"/>
  </xacro:macro>

  <!-- ========================= Base frames ========================= -->

  <!-- Ground projection of rear axle midpoint -->
  <link name="base_footprint"/>

  <!-- Main body reference frame: rear axle midpoint at wheel-center height -->
  <link name="base_link"/>
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ========================= Chassis body ========================= -->

  <link name="chassis_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="mk_mini_gray">
        <color rgba="0.30 0.33 0.38 1.0"/>
      </material>
    </visual>
  </link>

  <!--
    base_link is at wheel-center height, so body center z relative to base_link is:
    (ground_clearance + body_height/2) - wheel_radius
  -->
  <joint name="base_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_body"/>
    <origin xyz="${wheel_base / 2.0} 0 ${ground_clearance + body_height / 2.0 - wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ========================= Wheels ========================= -->

  <!-- Rear wheels rotate about their axle (local +y). -->
  <xacro:wheel_link name="rear_left_wheel" rgba="0.10 0.10 0.10 1.0"/>
  <joint name="base_to_rear_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0 ${half_track} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <xacro:wheel_link name="rear_right_wheel" rgba="0.10 0.10 0.10 1.0"/>
  <joint name="base_to_rear_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="0 ${-half_track} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front wheels: steer about local +z, then rotate about local +y. -->
  <xacro:steering_link name="front_left_steer"/>
  <joint name="base_to_front_left_steer" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_steer"/>
    <origin xyz="${wheel_base} ${half_track} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <xacro:wheel_link name="front_left_wheel" rgba="0.18 0.18 0.18 1.0"/>
  <joint name="front_left_steer_to_wheel" type="continuous">
    <parent link="front_left_steer"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <xacro:steering_link name="front_right_steer"/>
  <joint name="base_to_front_right_steer" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_steer"/>
    <origin xyz="${wheel_base} ${-half_track} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <xacro:wheel_link name="front_right_wheel" rgba="0.18 0.18 0.18 1.0"/>
  <joint name="front_right_steer_to_wheel" type="continuous">
    <parent link="front_right_steer"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ========================= LiDAR mount ========================= -->

  <link name="lidar_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.04"/>
      </geometry>
      <material name="lidar_mount_orange">
        <color rgba="0.95 0.45 0.15 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="body_to_lidar_mount" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_mount"/>
    <origin xyz="0.12 0 ${body_height / 2.0 + 0.02}" rpy="0 0 0"/>
  </joint>

</robot>